# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
build-last.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Pagefind search index (generated by npm run index:search — do not commit)
/public/pagefind/

# Editor temp files
*.tmp.*
.env*.local

# Internal reports / spreadsheets — never serve from public/
/public/**/*.csv
/public/**/*.xlsx
/public/**/*.xls
