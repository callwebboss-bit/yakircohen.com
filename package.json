{
  "name": "yakircohen-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:full": "next build && npm run index:search",
    "vercel-build": "npm run build:full",
    "index:search": "pagefind --site .next/server/app --glob \"**/*.html\" --output-path public/pagefind",
    "start": "next start",
    "lint": "eslint",
    "audit:images": "node scripts/audit-images.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:headings": "node scripts/audit-headings.mjs"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pagefind": "^1.3.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
