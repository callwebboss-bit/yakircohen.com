{
  "name": "yakircohen-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/run-with-lock.mjs next build",
    "build:stop": "node scripts/stop-builds.mjs",
    "verify:quick": "npm run test && npm run security:smoke",
    "security:smoke": "tsx scripts/security-smoke.ts",
    "verify:ci": "npm run lint && npm run test",
    "lint:security": "eslint --cache --cache-location node_modules/.cache/eslint lib/safe-json-ld.ts lib/sanitize-html.ts lib/embed-url.ts lib/form-validation.ts app/api/lead-notify/route.ts components/blog/BlogPostingJsonLd.tsx components/marketing/LazyClickEmbed.tsx \"app/(blog)/blog/[slug]/page.tsx\" scripts/run-with-lock.mjs scripts/stop-builds.mjs --max-warnings 0",
    "generate:schema": "tsx scripts/generate-site-schema.ts",
    "build:full": "node scripts/run-with-lock.mjs -- next build && npm run index:search",
    "sync:blog-slugs": "node scripts/sync-blog-slugs.mjs",
    "vercel-build": "npm run generate:schema && npm run sync:blog-slugs && npm run build:full",
    "index:search": "node scripts/prepare-pagefind.mjs && pagefind --site .pagefind-src --output-path public/pagefind && node -e \"require('fs').rmSync('.pagefind-src',{recursive:true,force:true})\"",
    "start": "next start",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint",
    "test": "node --import tsx --test hooks/useBookFlow.test.ts hooks/useBookingWizard.test.ts hooks/useLeadSubmit.test.ts lib/studio-form-draft.test.ts lib/events-form-draft.test.ts lib/singer-form-draft.test.ts",
    "audit:images": "node scripts/audit-images.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "audit:seo-titles": "node scripts/audit-seo-titles.mjs",
    "audit:schema": "node scripts/audit-schema.mjs",
    "audit:orphans": "node scripts/audit-orphans.mjs",
    "generate:og-images": "node scripts/generate-og-images.mjs",
    "audit:exclamation": "node scripts/audit-no-exclamation.mjs",
    "audit:pagefind": "node scripts/audit-pagefind.mjs",
    "audit:audio": "node scripts/audit-audio-demos.mjs",
    "audit:pricing": "node scripts/audit-pricing.mjs",
    "check:youtube": "node scripts/check-youtube-ids.mjs",
    "import:portfolio": "node scripts/import-portfolio.mjs",
    "audit:youtube": "node scripts/check-youtube-ids.mjs",
    "env:resend": "node scripts/push-resend-env.mjs",
    "export:closer": "node scripts/export-closer-config.mjs",
    "ingest:blog": "node scripts/ingest-blog-queue.mjs"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isomorphic-dompurify": "^3.16.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pagefind": "^1.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
